{
  "name": "@got/db-runtime",
  "version": "0.1.0",
  "description": "Zig-based database runtime for got graph database",
  "main": "build/lib.js",
  "type": "module",
  "scripts": {
    "watch": "find . -name \"*.zig\" | entr -r zig build run",
    "build": "zig build",
    "dev": "zig build && bun run test",
    "clean": "rm -rf zig-out zig-cache build"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@types/node": "latest"
  },
  "dependencies": {
    "@got/api-spec": "workspace:*"
  }
}